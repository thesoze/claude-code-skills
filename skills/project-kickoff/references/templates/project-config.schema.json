{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "project-kickoff config",
  "description": "Contract between a project and /project-kickoff. Records intent at kickoff time; audit mode diffs reality against this.",
  "type": "object",
  "required": ["schema_version", "kickoff_at", "tier", "intent", "installed", "drift_history"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "kickoff_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_audit_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "tier": {
      "type": "string",
      "enum": ["minimal", "standard", "paranoid"]
    },
    "intent": {
      "type": "object",
      "required": ["name", "description", "kind", "visibility", "stage"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["app", "library", "cli", "agent", "service", "research"]
        },
        "visibility": {
          "type": "string",
          "enum": ["public", "private", "solo-local"]
        },
        "stage": {
          "type": "string",
          "enum": ["greenfield", "existing", "forking"]
        },
        "stack": {
          "type": ["object", "null"],
          "properties": {
            "primary_language": { "type": "string" },
            "package_manager": { "type": "string" },
            "frameworks": { "type": "array", "items": { "type": "string" } }
          }
        },
        "threat_model": {
          "type": ["object", "null"],
          "properties": {
            "sources": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["user-urls", "web-scrape", "email", "rag-docs", "tool-outputs", "none"]
              }
            },
            "trust": {
              "type": ["string", "null"],
              "enum": ["me-only", "trusted-partners", "end-users", "internet", null]
            },
            "actions": {
              "type": ["array", "null"],
              "items": {
                "type": "string",
                "enum": ["read-only", "write-files", "shell-exec", "send-messages", "spend-money"]
              }
            },
            "cost": {
              "type": ["string", "null"],
              "enum": ["low", "medium", "high", null]
            }
          }
        },
        "conventions": {
          "type": "object",
          "properties": {
            "testing": {
              "type": ["string", "null"],
              "enum": ["strict-tdd", "pragmatic", "tests-later", "none", null]
            },
            "commit_style": {
              "type": ["string", "null"],
              "enum": ["conventional", "terse", "descriptive", null]
            }
          }
        },
        "git_identity": {
          "type": ["object", "null"],
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" }
          }
        },
        "user_overrode_safety_at_kickoff": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "installed": {
      "type": "object",
      "required": ["claude_md_sections", "hooks", "settings_keys"],
      "additionalProperties": false,
      "properties": {
        "claude_md_sections": {
          "type": "array",
          "items": { "type": "string" },
          "description": "names of sections managed under <!-- project-kickoff:* --> markers"
        },
        "hooks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "sha256"],
            "properties": {
              "path": { "type": "string" },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "event": {
                "type": "string",
                "enum": ["PreToolUse", "PostToolUse", "SessionStart", "Stop"]
              },
              "matcher": { "type": "string" }
            }
          }
        },
        "settings_keys": {
          "type": "array",
          "items": { "type": "string" },
          "description": "top-level .claude/settings.json keys this skill manages"
        },
        "scheduled_audit_id": {
          "type": ["string", "null"],
          "description": "ID of the routine created by /schedule, null if user declined"
        }
      }
    },
    "drift_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["at", "verdict"],
        "properties": {
          "at": { "type": "string", "format": "date-time" },
          "verdict": {
            "type": "string",
            "enum": ["PASS", "DRIFT", "BREACH", "INTENT-CHANGE"]
          },
          "breach_count": { "type": "integer", "minimum": 0 },
          "drift_count": { "type": "integer", "minimum": 0 },
          "intent_change_count": { "type": "integer", "minimum": 0 },
          "report_path": { "type": "string" }
        }
      }
    }
  }
}
